<Window x:Class="InstantReplay.OverlayNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="360" Height="86"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ShowActivated="False" Topmost="True"
        Focusable="False">
    <Border x:Name="Card"
            Background="#F2161B1E"
            BorderBrush="#FF283136"
            BorderThickness="1"
            CornerRadius="14"
            Padding="13">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="8"
                              Direction="270" Color="#CC000000" Opacity="0.62"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="42"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Width="34" Height="34" VerticalAlignment="Center">
                <Ellipse x:Name="IconRing" Stroke="#FF63E0BD" StrokeThickness="2"/>
                <TextBlock x:Name="IconText" Text="✓"
                           Foreground="#FF63E0BD"
                           FontFamily="Segoe UI Variable Display"
                           FontSize="16" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="5,0,0,0">
                <TextBlock x:Name="TitleText"
                           Foreground="#FFF1F5F4"
                           FontFamily="Segoe UI Variable Text"
                           FontSize="13.5" FontWeight="Bold"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="DetailText"
                           Foreground="#FF8F9BA2"
                           FontFamily="Segoe UI Variable Text"
                           FontSize="11.5"
                           Margin="0,4,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <Border Grid.ColumnSpan="2"
                    Height="2" VerticalAlignment="Bottom"
                    Margin="0,0,0,-13"
                    CornerRadius="1" Background="#22283136">
                <Border x:Name="LifeBar"
                        Background="#FF63E0BD"
                        RenderTransformOrigin="0,0.5"
                        HorizontalAlignment="Stretch">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="LifeScale" ScaleX="1"/>
                    </Border.RenderTransform>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>
