<Window x:Class="InstantReplay.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L.Brand}"
        Icon="Assets/Everloop.ico"
        Width="404" Height="430"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource FontUi}"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Border x:Name="WindowFrame"
            Background="{StaticResource BgWindowGradient}"
            BorderBrush="{StaticResource WindowBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusWindow}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="42" ShadowDepth="12" Direction="270" Opacity="0.58"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="54"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Margin="16,0"
                  Background="Transparent"
                  MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Ellipse Stroke="{StaticResource AccentBrush}" StrokeThickness="2.4"
                             StrokeDashArray="15,5" StrokeStartLineCap="Round"/>
                    <Ellipse Width="5" Height="5" Fill="{StaticResource AccentBrush}"/>
                </Grid>
                <TextBlock Grid.Column="1" Text="{DynamicResource L.Brand}" FontSize="14.5" FontWeight="ExtraBold"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="LanguageButton"
                            Style="{StaticResource IconButton}"
                            Width="30"
                            Content="{DynamicResource L.LanguageCode}"
                            FontSize="10.5"
                            FontWeight="ExtraBold"
                            Click="Language_Click"
                            ToolTip="{DynamicResource L.LanguageTip}"/>
                    <Button x:Name="SettingsButton" Style="{StaticResource IconButton}"
                            Click="Settings_Click" ToolTip="{DynamicResource L.Settings}">
                        <Path Data="{StaticResource IconGear}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.8" Width="15" Height="15" Stretch="Uniform"/>
                    </Button>
                    <Button x:Name="DoneButton"
                            Visibility="Collapsed"
                            Style="{StaticResource AccentButton}"
                            Content="{DynamicResource L.Done}"
                            Width="76"
                            Height="32"
                            Padding="12,0"
                            Margin="0,0,6,0"
                            FontSize="12.5"
                            Click="Apply_Click"/>
                    <Button Style="{StaticResource IconButton}" Click="Minimize_Click" ToolTip="{DynamicResource L.Minimize}">
                        <Path Data="M4 12h16" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.8" Width="13" Height="13" Stretch="Uniform"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Click="Close_Click" ToolTip="{DynamicResource L.Close}">
                        <Path Data="M6 6l12 12 M18 6L6 18"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.8" Width="13" Height="13" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>

            <StackPanel x:Name="DashboardPanel" Grid.Row="1" Margin="16,4,16,16">
                <Border Style="{StaticResource SettingsGroup}" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Width="46" Height="46" Margin="0,0,14,0">
                            <Ellipse Stroke="{StaticResource DividerBrush}" StrokeThickness="3"/>
                            <Ellipse x:Name="StatusRing" Stroke="{StaticResource AccentBrush}" StrokeThickness="3"
                                     StrokeDashArray="32,8" StrokeStartLineCap="Round"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform x:Name="StatusRingRotation"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="{StaticResource AccentBrush}"/>
                        </Grid>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="StatusTitleText" Text="{DynamicResource L.Status.Enabled}"
                                       FontSize="14.5" FontWeight="Bold"/>
                            <TextBlock x:Name="StatusDetailText" Text="{DynamicResource L.Status.Idle}"
                                       Style="{StaticResource SecondaryText}" Margin="0,3,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <ToggleButton x:Name="ReplayToggle" Grid.Column="2"
                                      Style="{StaticResource ToggleSwitch}"
                                      VerticalAlignment="Center"
                                      Click="ReplayToggle_Click"/>
                    </Grid>
                </Border>

                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ToggleButton x:Name="SystemSourceChip" Style="{StaticResource SourceChip}"
                                  Click="SourceChip_Click"
                                  ToolTip="{DynamicResource L.Audio.ToggleTip}">
                        <ToggleButton.ContextMenu>
                            <ContextMenu Style="{StaticResource TrayMenu}" Tag="system"
                                         Opened="AudioDeviceMenu_Opened"/>
                        </ToggleButton.ContextMenu>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Path Data="{StaticResource IconDisplay}"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                  StrokeThickness="1.8"
                                  Width="15" Height="15" Stretch="Uniform"/>
                            <TextBlock x:Name="PrimaryAudioChipText" Grid.Column="1"
                                       Text="{DynamicResource L.Audio.System}" Margin="8,0,0,0"/>
                            <Ellipse x:Name="SystemSourceDot" Grid.Column="2" Width="6" Height="6"
                                     Margin="8,0,0,0" Fill="{StaticResource AccentBrush}"/>
                        </Grid>
                    </ToggleButton>
                    <ToggleButton x:Name="MicSourceChip" Grid.Column="2" Style="{StaticResource SourceChip}"
                                  Click="SourceChip_Click"
                                  ToolTip="{DynamicResource L.Audio.ToggleTip}">
                        <ToggleButton.ContextMenu>
                            <ContextMenu Style="{StaticResource TrayMenu}" Tag="microphone"
                                         Opened="AudioDeviceMenu_Opened"/>
                        </ToggleButton.ContextMenu>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Path Data="{StaticResource IconMic}"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                  StrokeThickness="1.8"
                                  Width="15" Height="15" Stretch="Uniform"/>
                            <TextBlock Grid.Column="1" Text="{DynamicResource L.Audio.Microphone}" Margin="8,0,0,0"/>
                            <Ellipse x:Name="MicSourceDot" Grid.Column="2" Width="6" Height="6"
                                     Margin="8,0,0,0" Fill="{StaticResource AccentBrush}"/>
                        </Grid>
                    </ToggleButton>
                </Grid>

                <StackPanel Margin="4,13,4,0">
                    <Grid Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="CodecSummaryButton" Style="{StaticResource DashboardLinkButton}"
                                    Click="CodecSummary_Click" ToolTip="{DynamicResource L.OpenCodec}">
                                <TextBlock x:Name="CodecSummaryText" Text="H.264"
                                           FontFamily="{StaticResource FontMono}" FontSize="11.5"/>
                            </Button>
                            <TextBlock Text=" · " FontFamily="{StaticResource FontMono}" FontSize="11.5"
                                       Foreground="#FFAEB8BD"/>
                            <Button x:Name="FpsSummaryButton" Style="{StaticResource DashboardLinkButton}"
                                    Click="FpsSummary_Click" ToolTip="{DynamicResource L.OpenFps}">
                                <TextBlock x:Name="FpsSummaryText" Text="60 FPS"
                                           FontFamily="{StaticResource FontMono}" FontSize="11.5"/>
                            </Button>
                        </StackPanel>
                        <TextBlock x:Name="DiskSummaryText" Text="—" HorizontalAlignment="Right"
                                   Style="{StaticResource SecondaryText}"/>
                    </Grid>
                    <ProgressBar x:Name="DiskSummaryProgress" Style="{StaticResource DiskProgress}"
                                 Height="3" Minimum="0" Maximum="100"/>
                </StackPanel>

                <Button x:Name="SaveReplayButton" Style="{StaticResource AccentButton}"
                        HorizontalContentAlignment="Stretch"
                        Margin="0,14,0,0" Click="SaveReplay_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Path Data="{StaticResource IconDownload}"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  Width="16" Height="16" Stretch="Uniform" Margin="0,0,9,0"/>
                            <TextBlock x:Name="SaveButtonText" Text="Save 5 min"
                                       FontSize="13.5" FontWeight="ExtraBold"/>
                        </StackPanel>
                        <Border Grid.Column="2" Background="#29000000" CornerRadius="6"
                                Padding="7,3" HorizontalAlignment="Right" Margin="10,0,0,0">
                            <TextBlock x:Name="HotkeySummaryText" Text="Ctrl+Shift+F10"
                                       FontFamily="{StaticResource FontMono}" FontSize="10"/>
                        </Border>
                    </Grid>
                </Button>

                <Grid Margin="2,10,2,0">
                    <Path Data="{StaticResource IconFolder}" Stroke="{StaticResource TextMutedBrush}"
                          StrokeThickness="1.8" Width="12" Height="12" Stretch="Uniform"
                          HorizontalAlignment="Left"/>
                    <Button x:Name="OutputFolderSummaryButton" Margin="18,0,0,0"
                            HorizontalAlignment="Left" Style="{StaticResource DashboardLinkButton}"
                            Click="OutputFolderSummary_Click" ToolTip="{DynamicResource L.OpenFolderSettings}">
                        <TextBlock x:Name="OutputFolderSummaryText" Style="{StaticResource MonoText}"
                                   FontSize="10" MaxWidth="338" TextTrimming="CharacterEllipsis"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>
                </Grid>
            </StackPanel>

            <Grid x:Name="SettingsPanel" Grid.Row="1" Visibility="Collapsed">
                <ScrollViewer x:Name="SettingsScrollViewer"
                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Padding="16,0,10,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource L.Section.Replay}" Style="{StaticResource SectionHeaderText}" Margin="2,8,2,8"/>
                        <Border Style="{StaticResource SettingsGroup}">
                            <StackPanel>
                                <Grid Margin="13,11">
                                    <TextBlock Text="{DynamicResource L.Replay.Instant}" Style="{StaticResource RowLabelText}"/>
                                    <ToggleButton x:Name="SettingsReplayToggle" HorizontalAlignment="Right"
                                                  Style="{StaticResource ToggleSwitch}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <StackPanel Margin="13,11">
                                    <TextBlock Text="{DynamicResource L.Replay.BufferLength}" Style="{StaticResource RowLabelText}" Margin="0,0,0,8"/>
                                    <Border Style="{StaticResource SegmentStrip}">
                                        <UniformGrid x:Name="BufferOptions" Rows="1">
                                            <RadioButton GroupName="Buffer" Tag="15" Content="{DynamicResource L.Duration.15s}" Style="{StaticResource SegmentButton}"/>
                                            <RadioButton GroupName="Buffer" Tag="30" Content="{DynamicResource L.Duration.30s}" Style="{StaticResource SegmentButton}"/>
                                            <RadioButton GroupName="Buffer" Tag="60" Content="{DynamicResource L.Duration.1m}" Style="{StaticResource SegmentButton}"/>
                                            <RadioButton GroupName="Buffer" Tag="120" Content="{DynamicResource L.Duration.2m}" Style="{StaticResource SegmentButton}"/>
                                            <RadioButton GroupName="Buffer" Tag="300" Content="{DynamicResource L.Duration.5m}" Style="{StaticResource SegmentButton}"/>
                                            <RadioButton GroupName="Buffer" Tag="600" Content="{DynamicResource L.Duration.10m}" Style="{StaticResource SegmentButton}"/>
                                            <RadioButton GroupName="Buffer" Tag="900" Content="{DynamicResource L.Duration.15m}" Style="{StaticResource SegmentButton}"/>
                                        </UniformGrid>
                                    </Border>
                                </StackPanel>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Margin="13,11">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="190"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="{DynamicResource L.Replay.BufferLimit}"
                                                   Style="{StaticResource RowLabelText}"
                                                   ToolTip="{DynamicResource L.Replay.BufferLimitTip}"/>
                                        <TextBlock Text="{DynamicResource L.Replay.BufferLimitHint}"
                                                   Style="{StaticResource SecondaryText}"
                                                   FontSize="10" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ComboBox x:Name="ReplaySizeLimitBox" Grid.Column="1"
                                              Style="{StaticResource DarkCombo}">
                                        <ComboBoxItem Tag="0" Content="{DynamicResource L.Replay.DurationOnly}"/>
                                        <ComboBoxItem Tag="250" Content="{DynamicResource L.Size.250MB}"/>
                                        <ComboBoxItem Tag="500" Content="{DynamicResource L.Size.500MB}"/>
                                        <ComboBoxItem Tag="1000" Content="{DynamicResource L.Size.1GB}"/>
                                        <ComboBoxItem Tag="2000" Content="{DynamicResource L.Size.2GB}"/>
                                        <ComboBoxItem Tag="5000" Content="{DynamicResource L.Size.5GB}"/>
                                        <ComboBoxItem Tag="10000" Content="{DynamicResource L.Size.10GB}"/>
                                    </ComboBox>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Margin="13,11">
                                    <TextBlock Text="{DynamicResource L.Replay.StartWindows}" Style="{StaticResource RowLabelText}"/>
                                    <ToggleButton x:Name="AutostartBox" HorizontalAlignment="Right"
                                                  Style="{StaticResource ToggleSwitch}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{DynamicResource L.Section.Video}" Style="{StaticResource SectionHeaderText}"/>
                        <Border x:Name="VideoSettingsGroup" Style="{StaticResource SettingsGroup}">
                            <StackPanel>
                                <Grid Margin="13,11">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="190"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource L.Video.Source}" Style="{StaticResource RowLabelText}"/>
                                    <ComboBox x:Name="CaptureSourceBox" Grid.Column="1"
                                              Style="{StaticResource DarkCombo}"
                                              SelectionChanged="CaptureSourceBox_SelectionChanged">
                                        <ComboBoxItem Tag="desktop" Content="{DynamicResource L.Video.Desktop}"/>
                                        <ComboBoxItem Tag="game" Content="{DynamicResource L.Video.GameSource}"/>
                                    </ComboBox>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid x:Name="GameProcessRow" Margin="13,11">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="220"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource L.Video.Game}" Style="{StaticResource RowLabelText}"/>
                                        <TextBlock Text="{DynamicResource L.Video.GameCompatibility}"
                                                   Style="{StaticResource SecondaryText}"
                                                   FontSize="10" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ComboBox x:Name="GameProcessBox" Grid.Column="1"
                                              Style="{StaticResource DarkCombo}"
                                              DropDownOpened="GameProcessBox_DropDownOpened"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid x:Name="CodecSettingsRow" Margin="13,11">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="190"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="{DynamicResource L.Video.Codec}" Style="{StaticResource RowLabelText}"/>
                                        <TextBlock x:Name="HardwareEncoderText"
                                                   Style="{StaticResource SecondaryText}"
                                                   FontSize="10" Margin="0,2,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <ComboBox x:Name="CodecBox" Grid.Column="1"
                                              Style="{StaticResource DarkCombo}"
                                              SelectionChanged="CodecBox_SelectionChanged">
                                        <ComboBoxItem x:Name="H264CodecItem" Tag="h264"
                                                      Content="H.264 (AVC)"/>
                                        <ComboBoxItem x:Name="HevcCodecItem" Tag="hevc"
                                                      Content="H.265 (HEVC)"/>
                                        <ComboBoxItem x:Name="Av1CodecItem" Tag="av1"
                                                      Content="AV1"/>
                                    </ComboBox>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Margin="13,11">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="190"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource L.Video.Bitrate}" Style="{StaticResource RowLabelText}"/>
                                    <ComboBox x:Name="BitrateBox" Grid.Column="1" Style="{StaticResource DarkCombo}">
                                        <ComboBoxItem Tag="0" Content="{DynamicResource L.Video.AutoLoad}"/>
                                        <ComboBoxItem Tag="10" Content="{DynamicResource L.Video.Mbps10}"/>
                                        <ComboBoxItem Tag="20" Content="{DynamicResource L.Video.Mbps20}"/>
                                        <ComboBoxItem Tag="50" Content="{DynamicResource L.Video.Mbps50}"/>
                                        <ComboBoxItem Tag="80" Content="{DynamicResource L.Video.Mbps80}"/>
                                    </ComboBox>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Margin="13,11">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="220"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource L.Video.Monitor}" Style="{StaticResource RowLabelText}"/>
                                    <ComboBox x:Name="MonitorBox" Grid.Column="1" Style="{StaticResource DarkCombo}"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Margin="13,11">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="190"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource L.Video.Resolution}" Style="{StaticResource RowLabelText}"/>
                                    <ComboBox x:Name="ResolutionBox" Grid.Column="1"
                                              Style="{StaticResource DarkCombo}">
                                        <ComboBoxItem Tag="source" Content="{DynamicResource L.Video.SourceResolution}"/>
                                        <ComboBoxItem Tag="720p" Content="1280 × 720"/>
                                        <ComboBoxItem Tag="1080p" Content="1920 × 1080"/>
                                        <ComboBoxItem Tag="1440p" Content="2560 × 1440"/>
                                        <ComboBoxItem Tag="2160p" Content="3840 × 2160"/>
                                    </ComboBox>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <StackPanel x:Name="FpsSettingsRow" Margin="13,11">
                                    <TextBlock Text="{DynamicResource L.Video.FrameRate}" Style="{StaticResource RowLabelText}" Margin="0,0,0,8"/>
                                    <Border Style="{StaticResource SegmentStrip}">
                                        <UniformGrid x:Name="FpsOptions" Rows="1">
                                            <RadioButton GroupName="Fps" Tag="30" Content="30" Style="{StaticResource SegmentButton}"/>
                                            <RadioButton GroupName="Fps" Tag="60" Content="60" Style="{StaticResource SegmentButton}"/>
                                            <RadioButton GroupName="Fps" Tag="120" Content="120" Style="{StaticResource SegmentButton}"/>
                                            <RadioButton GroupName="Fps" Tag="144" Content="144" Style="{StaticResource SegmentButton}"/>
                                            <RadioButton GroupName="Fps" Tag="240" Content="240" Style="{StaticResource SegmentButton}"/>
                                        </UniformGrid>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{DynamicResource L.Section.Audio}" Style="{StaticResource SectionHeaderText}"/>
                        <Border Style="{StaticResource SettingsGroup}">
                            <StackPanel>
                                <Grid Margin="13,11">
                                    <TextBlock x:Name="SystemAudioLabel" Text="{DynamicResource L.Audio.SystemAudio}"
                                               Style="{StaticResource RowLabelText}"/>
                                    <ToggleButton x:Name="SystemAudioBox" HorizontalAlignment="Right"
                                                  Style="{StaticResource ToggleSwitch}" Click="AudioToggle_Click"/>
                                </Grid>
                                <ComboBox x:Name="AudioDeviceBox" Style="{StaticResource DarkCombo}" Margin="13,0,13,11"/>
                                <Grid x:Name="SystemVolumeRow" Margin="13,0,13,11">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="42"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource L.Audio.Volume}" Style="{StaticResource SecondaryText}"
                                               VerticalAlignment="Center"/>
                                    <Slider x:Name="SystemVolumeSlider" Grid.Column="1"
                                            Style="{StaticResource VolumeSlider}"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding ElementName=SystemVolumeSlider, Path=Value, StringFormat={}{0:0}%}"
                                               Style="{StaticResource MonoText}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Margin="13,11">
                                    <TextBlock Text="{DynamicResource L.Audio.Microphone}" Style="{StaticResource RowLabelText}"/>
                                    <ToggleButton x:Name="MicBox" HorizontalAlignment="Right"
                                                  Style="{StaticResource ToggleSwitch}" Click="AudioToggle_Click"/>
                                </Grid>
                                <ComboBox x:Name="MicDeviceBox" Style="{StaticResource DarkCombo}" Margin="13,0,13,11"/>
                                <Grid x:Name="MicVolumeRow" Margin="13,0,13,11">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="42"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource L.Audio.Volume}" Style="{StaticResource SecondaryText}"
                                               VerticalAlignment="Center"/>
                                    <Slider x:Name="MicVolumeSlider" Grid.Column="1"
                                            Style="{StaticResource VolumeSlider}"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding ElementName=MicVolumeSlider, Path=Value, StringFormat={}{0:0}%}"
                                               Style="{StaticResource MonoText}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid x:Name="MicBoostRow" Margin="13,0,13,11">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="48"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource L.Audio.Boost}" Style="{StaticResource SecondaryText}"
                                               VerticalAlignment="Center"
                                               ToolTip="{DynamicResource L.Audio.BoostTip}"/>
                                    <Slider x:Name="MicBoostSlider" Grid.Column="1"
                                            Style="{StaticResource VolumeSlider}"
                                            Maximum="20" TickFrequency="1"
                                            IsSnapToTickEnabled="True"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding ElementName=MicBoostSlider, Path=Value, StringFormat={}+{0:0} dB}"
                                               Style="{StaticResource MonoText}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Margin="13,11">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="190"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="{DynamicResource L.Audio.Tracks}" Style="{StaticResource RowLabelText}"/>
                                        <TextBlock x:Name="AudioTrackHintText" Text="{DynamicResource L.Audio.SystemAndMic}"
                                                   Style="{StaticResource SecondaryText}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <ComboBox x:Name="AudioTrackModeBox" Grid.Column="1"
                                              Style="{StaticResource DarkCombo}">
                                        <ComboBoxItem Tag="mixed" Content="{DynamicResource L.Audio.OneMixed}"/>
                                        <ComboBoxItem Tag="separate" Content="{DynamicResource L.Audio.Separate}"/>
                                    </ComboBox>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Margin="13,11">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="190"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource L.Audio.Codec}" Style="{StaticResource RowLabelText}"/>
                                    <ComboBox x:Name="AudioCodecBox" Grid.Column="1" Style="{StaticResource DarkCombo}">
                                        <ComboBoxItem Tag="aac" Content="AAC"/>
                                        <ComboBoxItem Tag="opus" Content="Opus · MKV"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{DynamicResource L.Section.Storage}" Style="{StaticResource SectionHeaderText}"/>
                        <Border x:Name="StorageSettingsGroup" Style="{StaticResource SettingsGroup}">
                            <StackPanel>
                                <Grid x:Name="OutputFolderSettingsRow" Margin="13,11">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="{DynamicResource L.Storage.ReplayFolder}" Style="{StaticResource RowLabelText}"/>
                                        <TextBlock x:Name="OutputDirText" Style="{StaticResource MonoText}" MaxWidth="250"/>
                                    </StackPanel>
                                    <Button x:Name="BrowseOutputButton" Grid.Column="1" Content="{DynamicResource L.Storage.Change}"
                                            Style="{StaticResource SubtleButton}"
                                            Click="BrowseOutput_Click"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <StackPanel Margin="13,11">
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock x:Name="DiskUsedText" Style="{StaticResource SecondaryText}"/>
                                        <TextBlock x:Name="DiskFreeText" HorizontalAlignment="Right"
                                                   Style="{StaticResource SecondaryText}"/>
                                    </Grid>
                                    <ProgressBar x:Name="DiskProgress" Style="{StaticResource DiskProgress}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{DynamicResource L.Section.Hotkeys}" Style="{StaticResource SectionHeaderText}"/>
                        <Border Style="{StaticResource SettingsGroup}">
                            <StackPanel>
                                <Grid Margin="13,11">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource L.Hotkey.SaveReplay}" Style="{StaticResource RowLabelText}"/>
                                        <TextBlock Text="{DynamicResource L.Hotkey.SaveHint}" Style="{StaticResource SecondaryText}"/>
                                    </StackPanel>
                                    <Button x:Name="SaveHotkeyButton" Grid.Column="1"
                                            Style="{StaticResource SubtleButton}" MinWidth="128"
                                            Tag="save" Click="HotkeyCapture_Click"/>
                                </Grid>
                                <Border Style="{StaticResource RowDivider}"/>
                                <Grid Margin="13,11">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource L.Hotkey.Toggle}" Style="{StaticResource RowLabelText}"/>
                                        <TextBlock Text="{DynamicResource L.Hotkey.ToggleHint}" Style="{StaticResource SecondaryText}"/>
                                    </StackPanel>
                                    <Button x:Name="ToggleHotkeyButton" Grid.Column="1"
                                            Style="{StaticResource SubtleButton}" MinWidth="128"
                                            Tag="toggle" Click="HotkeyCapture_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="{DynamicResource L.Hotkey.ApplyHint}"
                                   Style="{StaticResource SecondaryText}" TextAlignment="Center"
                                   Margin="8,14,8,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Border x:Name="NoticeBanner" Grid.RowSpan="2" Panel.ZIndex="20"
                    Visibility="Collapsed" Opacity="0"
                    VerticalAlignment="Bottom" Margin="16"
                    Background="#FF171C1F" BorderBrush="#FF5A3B35" BorderThickness="1"
                    CornerRadius="11" Padding="12">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="NoticeTranslate" Y="12"/>
                </Border.RenderTransform>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="14" Background="#26E0A163"
                            BorderBrush="{StaticResource ErrorBrush}" BorderThickness="1">
                        <TextBlock Text="!" Foreground="{StaticResource ErrorBrush}"
                                   FontWeight="ExtraBold" FontSize="15"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0">
                        <TextBlock x:Name="NoticeTitleText" Text="{DynamicResource L.Error}"
                                   FontSize="12.5" FontWeight="Bold"/>
                        <TextBlock x:Name="NoticeMessageText" Text=""
                                   Style="{StaticResource SecondaryText}"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="2" Style="{StaticResource IconButton}"
                            Width="24" Height="24" Click="NoticeClose_Click">
                        <Path Data="M6 6l12 12 M18 6L6 18"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.8" Width="11" Height="11" Stretch="Uniform"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
